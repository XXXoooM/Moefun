---
import { Icon } from "astro-icon/components";

interface Props {
	class?: string;
	style?: string;
	id?: string;
}
const { class: className, style, id } = Astro.props;

const viewConfigStr = JSON.stringify({
	showLyrics: true,
	i18n: {
		noPlaying: "暂无播放",
		lyrics: "歌词",
		noLyrics: "暂无歌词",
		loadingLyrics: "加载中...",
		failedLyrics: "加载失败",
		noSongs: "暂无歌曲",
		error: "出错啦",
		play: "播放",
		pause: "暂停",
		noCover: "暂无封面",
		music: "音乐",
	},
});

const widgetId = id || `music-widget-${Math.random().toString(36).substring(2, 9)}`;
---

<div id={widgetId} class:list={["card-base p-4 music-player-widget w-full relative transition-all duration-300 overflow-hidden", className]} style={style} role="region" aria-label="音乐播放器">

    <!-- Top Row: Cover & Info -->
    <div class="flex items-center gap-3 mb-3 px-1">
        <!-- Circular Cover -->
        <div class="relative shrink-0 w-16 h-16 group">
            <div class="w-full h-full rounded-full overflow-hidden shadow-lg border-2 border-[var(--primary)] relative z-10 bg-[var(--primary)]/10 flex items-center justify-center">
                <Icon name="material-symbols:music-note-rounded" class="text-2xl text-[var(--primary)] opacity-40 absolute" aria-hidden="true" />
                <img class="music-cover w-full h-full max-w-full max-h-full object-cover animate-spin-slow relative z-10 opacity-0 transition-opacity duration-300" src="" alt="封面" style="animation-play-state: paused;" />
            </div>
        </div>

        <!-- Info Section -->
        <div class="flex-1 min-w-0 flex flex-col overflow-hidden">
            <div class="flex items-center justify-between overflow-hidden gap-2">
                <div class="flex-1 min-w-0 overflow-hidden relative">
                    <h3 class="music-title font-bold text-base text-[var(--title-active)] leading-tight truncate">
                        音乐
                    </h3>
                </div>
                <!-- Top Right: Lyric Toggle -->
                <button class="btn-lrc-toggle hover:text-[var(--primary)] transition-all duration-300 transform active:scale-95 text-neutral-400 shrink-0" title="歌词" aria-label="歌词">
                    <Icon name="material-symbols:subtitles-outline-rounded" class="icon-lrc-on text-xl hidden" aria-hidden="true" />
                    <Icon name="material-symbols:subtitles-off-outline-rounded" class="icon-lrc-off text-xl" aria-hidden="true" />
                </button>
            </div>

            <div class="min-w-0 overflow-hidden mt-1">
                <p class="music-artist text-xs font-medium text-neutral-500 dark:text-neutral-400 truncate opacity-80">
                    暂无播放
                </p>
            </div>

            <!-- Time Display & Volume -->
            <div class="flex items-center gap-2 text-neutral-400 h-5 mt-auto">
                <div class="text-[10px] font-mono flex items-center gap-1 shrink-0 h-full opacity-60" aria-live="polite">
                    <span class="current-time">0:00</span>
                    <span class="opacity-50" aria-hidden="true">/</span>
                    <span class="total-time">0:00</span>
                </div>

                <!-- Volume -->
                <div class="flex items-center gap-1 bg-transparent h-full flex-1">
                    <button class="btn-mute hover:text-[var(--primary)] transition-colors p-0.5 rounded-md flex items-center" title="静音" aria-label="静音">
                        <Icon name="material-symbols:volume-up-rounded" class="icon-vol-high text-base" aria-hidden="true" />
                        <Icon name="material-symbols:volume-off-rounded" class="icon-vol-mute text-base hidden" aria-hidden="true" />
                    </button>
                    <div class="vol-container h-1 min-w-12 flex-1 bg-neutral-200 dark:bg-neutral-700/50 rounded-full cursor-pointer relative ml-1" role="slider" aria-label="音量" aria-valuemin="0" aria-valuemax="100" aria-valuenow="70">
                        <div class="vol-bar absolute left-0 top-0 h-full bg-[var(--primary)] rounded-full w-[70%]"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Progress Bar (Slim) -->
    <div class="progress-container relative w-full h-1 bg-neutral-100 dark:bg-white/5 rounded-full cursor-pointer touch-none mb-3 group" role="slider" aria-label="播放进度" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">
        <div class="progress-bar absolute left-0 top-0 h-full bg-[var(--primary)] rounded-full w-0 transition-[width] duration-100 shadow-[0_0_8px_var(--primary)]/50"></div>
        <div class="progress-thumb absolute top-1/2 -mt-1.5 -ml-1.5 w-3 h-3 bg-[var(--primary)] border-2 border-white dark:border-neutral-800 rounded-full shadow-sm scale-0 group-hover:scale-100 transition-transform duration-200"></div>
    </div>

    <!-- Controls Row -->
    <div class="flex items-center justify-between px-1 select-none">
        <!-- Repeat Mode -->
        <button class="btn-repeat text-neutral-400 dark:text-neutral-500 hover:text-[var(--primary)] transition-colors p-2 active:scale-95" title="模式" aria-label="播放模式">
            <Icon name="material-symbols:repeat-rounded" class="icon-repeat text-xl" aria-hidden="true" />
            <Icon name="material-symbols:repeat-one-rounded" class="icon-repeat-one text-xl hidden" aria-hidden="true" />
            <Icon name="material-symbols:shuffle-rounded" class="icon-shuffle text-xl hidden" aria-hidden="true" />
        </button>

        <!-- Prev -->
        <button class="btn-prev text-neutral-600 dark:text-neutral-300 hover:text-[var(--primary)] transition-colors p-2 active:scale-95" title="上一首">
            <Icon name="material-symbols:skip-previous-rounded" class="text-2xl" aria-hidden="true" />
        </button>

        <!-- Play/Pause -->
        <button class="btn-play w-10 h-10 bg-[var(--primary)]/10 text-[var(--primary)] hover:bg-[var(--primary)] hover:text-white rounded-full flex items-center justify-center transition-all duration-300 shadow-sm" title="播放">
            <Icon name="material-symbols:play-arrow-rounded" class="icon-play text-2xl ml-0.5" aria-hidden="true" />
            <Icon name="material-symbols:pause-rounded" class="icon-pause text-2xl hidden" aria-hidden="true" />
        </button>

        <!-- Next -->
        <button class="btn-next text-neutral-600 dark:text-neutral-300 hover:text-[var(--primary)] transition-colors p-2 active:scale-95" title="下一首">
            <Icon name="material-symbols:skip-next-rounded" class="text-2xl" aria-hidden="true" />
        </button>

        <!-- Playlist Toggle -->
        <button class="btn-drawer-toggle text-neutral-400 hover:text-[var(--primary)] transition-all duration-300 p-2 transform active:scale-95" title="歌单">
            <Icon name="material-symbols:playlist-play-rounded" class="text-xl" aria-hidden="true" />
        </button>
    </div>

    <!-- Lyrics Drawer -->
    <div class="lrc-drawer grid transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] grid-rows-[0fr] opacity-0 overflow-hidden w-full">
        <div class="min-h-0 overflow-hidden bg-neutral-100/50 dark:bg-black/10 rounded-xl mt-3">
            <div class="lrc-container h-40 overflow-y-auto custom-scrollbar flex flex-col items-center gap-2 p-4 py-16 text-center relative scroll-smooth text-neutral-400 text-sm">
                载入中...
            </div>
        </div>
    </div>

    <!-- Playlist Drawer -->
    <div class="playlist-drawer grid transition-all duration-500 ease-[cubic-bezier(0.4,0,0.2,1)] grid-rows-[0fr] opacity-0 overflow-hidden w-full">
        <div class="min-h-0 overflow-hidden bg-neutral-100/50 dark:bg-black/10 rounded-xl mt-3">
            <div class="playlist-container max-h-48 overflow-y-auto custom-scrollbar p-2 flex flex-col gap-1">
                <!-- Tracks list -->
            </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div class="music-loading absolute inset-0 z-20 flex flex-col items-center justify-center bg-white/40 dark:bg-black/40 backdrop-blur-[1px] transition-opacity duration-300 opacity-0 pointer-events-none rounded-xl">
        <Icon name="material-symbols:sync-rounded" class="text-2xl text-[var(--primary)] animate-spin" />
    </div>
</div>

<template id={`playlist-item-template-${widgetId}`}>
    <div class="playlist-item flex items-center gap-2 p-2 rounded-lg cursor-pointer hover:bg-neutral-200/50 dark:hover:bg-white/5 transition-all group">
        <div class="w-8 h-8 rounded-md overflow-hidden shrink-0 relative bg-neutral-200 dark:bg-neutral-800">
            <img src="" class="item-cover w-full h-full object-cover" loading="lazy" />
            <div class="item-active-overlay absolute inset-0 bg-[var(--primary)]/20 hidden items-center justify-center">
                <Icon name="material-symbols:graphic-eq-rounded" class="text-[var(--primary)] text-sm" />
            </div>
        </div>
        <div class="flex-1 min-w-0">
            <div class="item-title text-xs font-bold text-neutral-700 dark:text-neutral-200 truncate group-hover:text-[var(--primary)] transition-colors"></div>
            <div class="item-artist text-[10px] text-neutral-400 truncate opacity-60"></div>
        </div>
    </div>
</template>

<script is:inline data-swup-ignore-script define:vars={{ viewConfigStr, widgetId }} >
(function () {
    var cfg = JSON.parse(viewConfigStr);
    var widget = document.getElementById(widgetId);
    if (!widget) return;

    var mgr = window.__fireflyMusic;
    if (!mgr) return;

    var ui = {
        widget: widget,
        loading: widget.querySelector('.music-loading'),
        cover: widget.querySelector('.music-cover'),
        title: widget.querySelector('.music-title'),
        artist: widget.querySelector('.music-artist'),
        progressBar: widget.querySelector('.progress-bar'),
        progressThumb: widget.querySelector('.progress-thumb'),
        progressContainer: widget.querySelector('.progress-container'),
        currentTime: widget.querySelector('.current-time'),
        totalTime: widget.querySelector('.total-time'),
        btnPlay: widget.querySelector('.btn-play'),
        iconPlay: widget.querySelector('.icon-play'),
        iconPause: widget.querySelector('.icon-pause'),
        btnPrev: widget.querySelector('.btn-prev'),
        btnNext: widget.querySelector('.btn-next'),
        btnRepeat: widget.querySelector('.btn-repeat'),
        iconRepeat: widget.querySelector('.icon-repeat'),
        iconRepeatOne: widget.querySelector('.icon-repeat-one'),
        iconShuffle: widget.querySelector('.icon-shuffle'),
        btnMute: widget.querySelector('.btn-mute'),
        iconVolHigh: widget.querySelector('.icon-vol-high'),
        iconVolMute: widget.querySelector('.icon-vol-mute'),
        volContainer: widget.querySelector('.vol-container'),
        volBar: widget.querySelector('.vol-bar'),
        btnLrc: widget.querySelector('.btn-lrc-toggle'),
        iconLrcOn: widget.querySelector('.icon-lrc-on'),
        iconLrcOff: widget.querySelector('.icon-lrc-off'),
        lrcDrawer: widget.querySelector('.lrc-drawer'),
        lrcContainer: widget.querySelector('.lrc-container'),
        btnDrawer: widget.querySelector('.btn-drawer-toggle'),
        playlistDrawer: widget.querySelector('.playlist-drawer'),
        playlistContainer: widget.querySelector('.playlist-container'),
        itemTemplate: document.getElementById('playlist-item-template-' + widgetId)
    };

    var local = {
        isUserScrolling: false,
        scrollTimeout: null,
        currentLrcIndex: -1
    };

    function setLoading(bool) {
        if (bool) ui.loading.classList.remove('opacity-0', 'pointer-events-none');
        else ui.loading.classList.add('opacity-0', 'pointer-events-none');
    }

    function updatePlayStateUI(isPlaying) {
        if (isPlaying) {
            ui.btnPlay.classList.add('bg-[var(--primary)]', 'text-white');
            ui.iconPlay.classList.add('hidden');
            ui.iconPause.classList.remove('hidden');
            ui.cover.style.animationPlayState = 'running';
        } else {
            ui.btnPlay.classList.remove('bg-[var(--primary)]', 'text-white');
            ui.iconPlay.classList.remove('hidden');
            ui.iconPause.classList.add('hidden');
            ui.cover.style.animationPlayState = 'paused';
        }
    }

    function updateModeUI(playMode) {
        var primaryColor = 'text-[var(--primary)]';
        if (playMode === 0) {
            ui.btnRepeat.className = 'p-2 active:scale-95 transition-colors text-neutral-400 dark:text-neutral-500 hover:text-[var(--primary)]';
            ui.iconRepeat.classList.remove('hidden');
            ui.iconRepeatOne.classList.add('hidden');
            ui.iconShuffle.classList.add('hidden');
        } else if (playMode === 1) {
            ui.btnRepeat.className = 'p-2 active:scale-95 transition-colors ' + primaryColor;
            ui.iconRepeat.classList.add('hidden');
            ui.iconRepeatOne.classList.remove('hidden');
            ui.iconShuffle.classList.add('hidden');
        } else {
            ui.btnRepeat.className = 'p-2 active:scale-95 transition-colors ' + primaryColor;
            ui.iconRepeat.classList.add('hidden');
            ui.iconRepeatOne.classList.add('hidden');
            ui.iconShuffle.classList.remove('hidden');
        }
    }

    function updateVolumeUI(volume, isMuted) {
        var pct = isMuted ? 0 : volume * 100;
        ui.volBar.style.width = pct + '%';
        if (isMuted || volume === 0) {
            ui.iconVolHigh.classList.add('hidden');
            ui.iconVolMute.classList.remove('hidden');
        } else {
            ui.iconVolHigh.classList.remove('hidden');
            ui.iconVolMute.classList.add('hidden');
        }
    }

    function updateTrackUI(track) {
        if (!track) return;
        ui.title.innerText = track.name;
        ui.artist.innerText = track.artist;
        if (track.pic) {
            ui.cover.classList.add('opacity-0');
            ui.cover.src = track.pic;
        } else ui.cover.src = '';
    }

    function renderPlaylist(playlist, currentIndex) {
        ui.playlistContainer.innerHTML = '';
        playlist.forEach(function (track, idx) {
            var clone = ui.itemTemplate.content.cloneNode(true);
            var itemEl = clone.querySelector('.playlist-item');
            clone.querySelector('.item-cover').src = track.pic || '';
            clone.querySelector('.item-title').innerText = track.name;
            clone.querySelector('.item-artist').innerText = track.artist;
            itemEl.onclick = function () { mgr.playTrackByIndex(idx); };
            ui.playlistContainer.appendChild(clone);
        });
        updatePlaylistActiveUI(currentIndex);
    }

    function updatePlaylistActiveUI(currentIndex) {
        var items = ui.playlistContainer.querySelectorAll('.playlist-item');
        items.forEach(function (el, idx) {
            var overlay = el.querySelector('.item-active-overlay');
            var title = el.querySelector('.item-title');
            if (idx === currentIndex) {
                el.classList.add('bg-neutral-200/50', 'dark:bg-white/10');
                overlay.classList.remove('hidden'); overlay.classList.add('flex');
                title.classList.add('text-[var(--primary)]');
            } else {
                el.classList.remove('bg-neutral-200/50', 'dark:bg-white/10');
                overlay.classList.add('hidden'); overlay.classList.remove('flex');
                title.classList.remove('text-[var(--primary)]');
            }
        });
    }

    function renderLyricsUI(lyrics, status) {
        local.currentLrcIndex = -1;
        ui.lrcContainer.innerHTML = '';
        if (status === 'loading') { ui.lrcContainer.innerHTML = '正在载入...'; return; }
        if (status === 'failed') { ui.lrcContainer.innerHTML = '载入失败'; return; }
        if (!lyrics || lyrics.length === 0) { ui.lrcContainer.innerHTML = '暂无歌词'; return; }
        lyrics.forEach(function (line, index) {
            var lineEl = document.createElement('div');
            lineEl.className = 'lrc-line transition-all duration-300 py-1 cursor-pointer hover:text-[var(--primary)]';
            lineEl.innerText = line.text;
            lineEl.onclick = function () { mgr.seekToTime(line.time); };
            ui.lrcContainer.appendChild(lineEl);
        });
    }

    function updateLrcHighlight(index) {
        if (index === local.currentLrcIndex) return;
        local.currentLrcIndex = index;
        var lines = ui.lrcContainer.querySelectorAll('.lrc-line');
        lines.forEach(function (line, i) {
            if (i === index) {
                line.classList.add('text-[var(--primary)]', 'font-black', 'text-base');
                line.classList.remove('text-neutral-400');
            } else {
                line.classList.remove('text-[var(--primary)]', 'font-black', 'text-base');
                line.classList.add('text-neutral-400');
            }
        });
        if (index !== -1 && !local.isUserScrolling) {
            var line = lines[index];
            if (line) {
                var targetScroll = line.offsetTop - (ui.lrcContainer.clientHeight / 2) + (line.offsetHeight / 2);
                ui.lrcContainer.scrollTo({ top: targetScroll, behavior: 'smooth' });
            }
        }
    }

    function syncAll() {
        var s = mgr.getState();
        if (!s.initialized) return;
        setLoading(false);
        if (s.playlist.length === 0) { ui.title.innerText = '暂无歌曲'; return; }
        renderPlaylist(s.playlist, s.currentIndex);
        if (s.track) updateTrackUI(s.track);
        updatePlayStateUI(s.isPlaying);
        updateModeUI(s.playMode);
        updateVolumeUI(s.volume, s.isMuted);
    }

    window.addEventListener('fm:init', syncAll);
    window.addEventListener('fm:track', function (e) { updateTrackUI(e.detail.track); updatePlaylistActiveUI(e.detail.index); });
    window.addEventListener('fm:play-state', function (e) { updatePlayStateUI(e.detail.isPlaying); });
    window.addEventListener('fm:time', function (e) {
        var d = e.detail;
        ui.progressBar.style.width = d.progress + '%';
        ui.progressThumb.style.left = d.progress + '%';
        ui.currentTime.innerText = d.currentTimeStr;
        ui.totalTime.innerText = d.durationStr;
    });
    window.addEventListener('fm:volume', function (e) { updateVolumeUI(e.detail.volume, e.detail.isMuted); });
    window.addEventListener('fm:mode', function (e) { updateModeUI(e.detail.playMode); });
    window.addEventListener('fm:lyrics', function (e) { renderLyricsUI(e.detail.lyrics, e.detail.status); });
    window.addEventListener('fm:lrc-index', function (e) { updateLrcHighlight(e.detail.index); });

    ui.btnPlay.onclick = function () { mgr.togglePlay(); };
    ui.btnNext.onclick = function () { mgr.playNext(); };
    ui.btnPrev.onclick = function () { mgr.playPrev(); };
    ui.btnRepeat.onclick = function () { mgr.cyclePlayMode(); };
    ui.btnMute.onclick = function () { mgr.toggleMute(); };
    
    ui.volContainer.onclick = function (e) {
        var val = (e.clientX - ui.volContainer.getBoundingClientRect().left) / ui.volContainer.clientWidth;
        mgr.setVolume(val);
    };
    ui.progressContainer.onclick = function (e) {
        var percent = (e.clientX - ui.progressContainer.getBoundingClientRect().left) / ui.progressContainer.clientWidth;
        mgr.seek(percent);
    };

    ui.btnLrc.onclick = function () {
        var isOpen = ui.lrcDrawer.style.gridTemplateRows === '1fr';
        ui.lrcDrawer.style.gridTemplateRows = isOpen ? '0fr' : '1fr';
        ui.lrcDrawer.classList.toggle('opacity-100', !isOpen); ui.lrcDrawer.classList.toggle('opacity-0', isOpen);
        ui.iconLrcOn.classList.toggle('hidden', isOpen); ui.iconLrcOff.classList.toggle('hidden', !isOpen);
        if(!isOpen) { ui.playlistDrawer.style.gridTemplateRows = '0fr'; ui.playlistDrawer.classList.add('opacity-0'); }
    };

    ui.btnDrawer.onclick = function () {
        var isOpen = ui.playlistDrawer.style.gridTemplateRows === '1fr';
        ui.playlistDrawer.style.gridTemplateRows = isOpen ? '0fr' : '1fr';
        ui.playlistDrawer.classList.toggle('opacity-100', !isOpen); ui.playlistDrawer.classList.toggle('opacity-0', isOpen);
        if(!isOpen) { ui.lrcDrawer.style.gridTemplateRows = '0fr'; ui.lrcDrawer.classList.add('opacity-0'); }
    };

    ui.cover.onload = function () { ui.cover.classList.remove('opacity-0'); };

    if (mgr.getState().initialized) syncAll();
    else { setLoading(true); mgr.init(); }
})();
</script>

<style>
    @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    .animate-spin-slow {
        animation: spin-slow 15s linear infinite;
    }
</style>
