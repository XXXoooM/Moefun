---
import WidgetLayout from "./WidgetLayout.astro";
import Calendar from "./Calendar.svelte";
import { getSortedPosts } from "@utils/content-utils";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// 获取所有文章的发布日期
const posts = await getSortedPosts();
const postDates = posts.map(post => post.data.published.toISOString());
---

<WidgetLayout name="日历" id="calendar-widget" class={className} style={style}>
    <Calendar client:only="svelte" postDates={postDates} />
</WidgetLayout>
