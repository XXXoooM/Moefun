---
import { Icon } from "astro-icon/components";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	class?: string;
	style?: string;
}

const { class: className, style } = Astro.props;

// Worker URL - you need to create a weather worker and set this
const weatherApiUrl = "https://moefun.yuia.fun/api/weather";
---

<WidgetLayout name="天气" id="weather-widget" class={className} style={style}>
  <div class="weather-content" id="weather-content">
    <div class="weather-loading">
      <Icon name="material-symbols:cloud-sync-outline" class="text-[1.5rem] text-[var(--primary)] animate-pulse" />
      <span class="text-xs text-50">正在获取天气...</span>
    </div>
  </div>
</WidgetLayout>

<style>
  .weather-content {
    min-height: 3.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .weather-loading {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  /* Loaded state */
  :global(.weather-loaded) {
    display: flex;
    flex-direction: column;
    padding: 0.25rem;
    width: 100%;
  }

  :global(.weather-main-panel) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
  }

  :global(.weather-expand-btn) {
    cursor: pointer;
    background: none;
    border: none;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.weather-widget-expanded .weather-expand-btn) {
    transform: translateY(-50%) rotate(180deg);
  }

  :global(.weather-detail-panel) {
    width: 100%;
    /* Keep max-height and opacity transitions defined in inline classes, just ensuring block display */
    display: block;
  }

  :global(.weather-widget-expanded .weather-detail-panel) {
    max-height: 200px;
    opacity: 1;
  }

  :global(.weather-icon-display) {
    font-size: 2.25rem;
    line-height: 1;
    flex-shrink: 0;
  }

  :global(.weather-info) {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }

  :global(.weather-temp-row) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  :global(.weather-temp) {
    font-weight: 700;
    font-size: 1.35rem;
    color: rgba(0, 0, 0, 0.85);
    line-height: 1.2;
  }

  :global(.dark) :global(.weather-temp) {
    color: rgba(255, 255, 255, 0.9);
  }

  :global(.weather-desc) {
    font-size: 0.8rem;
    color: rgba(0, 0, 0, 0.5);
    font-weight: 500;
  }

  :global(.dark) :global(.weather-desc) {
    color: rgba(255, 255, 255, 0.45);
  }

  :global(.weather-meta) {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.7rem;
    color: rgba(0, 0, 0, 0.4);
    font-weight: 500;
  }

  :global(.dark) :global(.weather-meta) {
    color: rgba(255, 255, 255, 0.35);
  }

  :global(.weather-meta-item) {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }

  :global(.weather-greeting) {
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.45);
    margin-top: 0.25rem;
    padding-top: 0.375rem;
    border-top: 1px dashed rgba(0, 0, 0, 0.06);
    line-height: 1.4;
  }

  :global(.dark) :global(.weather-greeting) {
    color: rgba(255, 255, 255, 0.4);
    border-color: rgba(255, 255, 255, 0.06);
  }

  /* Error state */
  :global(.weather-error) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
    font-size: 0.8rem;
    color: rgba(0, 0, 0, 0.4);
  }

  :global(.dark) :global(.weather-error) {
    color: rgba(255, 255, 255, 0.35);
  }
</style>

<script is:inline define:vars={{ weatherApiUrl }}>
  (function() {
    var CACHE_KEY = 'weather-location';
    var CACHE_TTL = 30 * 60 * 1000; // 30 minutes

    // ---- Location helpers ----
    function getCachedLocation() {
      try {
        var raw = localStorage.getItem(CACHE_KEY);
        if (!raw) return null;
        var data = JSON.parse(raw);
        if (Date.now() - data.timestamp < CACHE_TTL) {
          return { lat: data.lat, lon: data.lon, name: data.name };
        }
      } catch (e) {}
      return null;
    }

    function cacheLocation(lat, lon, name) {
      try {
        localStorage.setItem(CACHE_KEY, JSON.stringify({
          lat: lat, lon: lon, name: name, timestamp: Date.now()
        }));
      } catch (e) {}
    }

    function getGPS() {
      return new Promise(function(resolve) {
        if (!navigator.geolocation) { resolve(null); return; }
        navigator.geolocation.getCurrentPosition(
          function(pos) {
            resolve({ lat: pos.coords.latitude, lon: pos.coords.longitude, name: 'GPS 定位' });
          },
          function() { resolve(null); },
          { timeout: 3000, maximumAge: 600000 }
        );
      });
    }

    // ---- Weather code mappings ----
    function getWeatherDesc(code) {
      var map = {
        0: '晴朗', 1: '大部晴朗', 2: '少云', 3: '多云',
        45: '有雾', 48: '雾凇',
        51: '小毛毛雨', 53: '中毛毛雨', 55: '大毛毛雨',
        56: '冻毛毛雨', 57: '强冻毛毛雨',
        61: '小雨', 63: '中雨', 65: '大雨',
        66: '冻雨', 67: '强冻雨',
        71: '小雪', 73: '中雪', 75: '大雪',
        77: '雪粒',
        80: '阵雨', 81: '中阵雨', 82: '强阵雨',
        85: '小阵雪', 86: '大阵雪',
        95: '雷暴', 96: '雷暴伴冰雹', 99: '雷暴伴大冰雹'
      };
      return map[code] || '未知';
    }

    function getWeatherIcon(code) {
      if (code === 0 || code === 1) return '☀️';
      if (code === 2) return '⛅';
      if (code === 3) return '☁️';
      if (code >= 45 && code <= 48) return '🌫️';
      if (code >= 51 && code <= 57) return '🌧️';
      if (code >= 61 && code <= 67) return '🌧️';
      if (code >= 71 && code <= 77) return '❄️';
      if (code >= 80 && code <= 82) return '🌦️';
      if (code >= 85 && code <= 86) return '🌨️';
      if (code >= 95) return '⛈️';
      return '🌤️';
    }

    function getGreeting(code, temp) {
      if (code >= 95) return '⚡ 雷雨天气，注意安全！';
      if (code >= 61 && code <= 67) return '☔ 下雨了，记得带伞哦';
      if (code >= 71 && code <= 86) return '🧣 下雪天，注意保暖';
      if (temp > 35) return '🌡️ 天气炎热，注意防暑';
      if (temp > 30) return '🧊 天气较热，多喝水';
      if (temp < 0) return '🧊 天寒地冻，多穿一点';
      if (temp < 10) return '🧥 天气微凉，添件外套';
      if (code <= 1) return '🌈 天气晴好，心情愉快！';
      return '🌈 祝你有美好的一天！';
    }

    function formatTime(isoString) {
      if (!isoString) return '--:--';
      var d = new Date(isoString);
      var h = d.getHours().toString().padStart(2, '0');
      var m = d.getMinutes().toString().padStart(2, '0');
      return h + ':' + m;
    }

    // ---- Render ----
    function renderWeather(container, data) {
      if (data.error || data.temperature === undefined) {
        container.innerHTML = '<div class="weather-error">⚠️ 天气信息暂不可用</div>';
        return;
      }

      var icon = getWeatherIcon(data.weathercode);
      var desc = getWeatherDesc(data.weathercode);
      var greeting = getGreeting(data.weathercode, data.temperature);
      var sunrise = formatTime(data.sunrise);
      var sunset = formatTime(data.sunset);

      container.innerHTML =
        '<div class="weather-loaded">' +
          '<div class="weather-main-panel relative">' +
            '<div class="weather-icon-display">' + icon + '</div>' +
            '<div class="weather-info">' +
              '<div class="weather-temp-row relative">' +
                '<span class="weather-temp">' + data.temperature + '°C</span>' +
                '<span class="weather-desc">' + desc + '</span>' +
                '<button class="weather-expand-btn absolute right-0 top-1/2 -translate-y-1/2" aria-label="展开更多" title="展开详细天气">' +
                  '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-black/30 dark:text-white/30 hover:text-black/60 dark:hover:text-white/60 transition-colors"><path d="m6 9 6 6 6-6"/></svg>' +
                '</button>' +
              '</div>' +
              '<div class="weather-meta">' +
                '<span class="weather-meta-item">📍 ' + data.city + '</span>' +
                '<span class="weather-meta-item">💨 ' + data.windspeed + 'km/h</span>' +
              '</div>' +
              '<div class="weather-greeting">' + greeting + '</div>' +
            '</div>' +
          '</div>' +
          '<div class="weather-detail-panel overflow-hidden transition-all duration-300 max-h-0 opacity-0 w-full">' +
            '<div class="grid grid-cols-2 gap-2 mt-3 pt-3 border-t border-dashed border-black/10 dark:border-white/10 text-[0.7rem] text-black/60 dark:text-white/60">' +
              '<div>💧 湿度: ' + (data.humidity !== undefined ? data.humidity + '%' : '--') + '</div>' +
              '<div>🌡️ 体感: ' + (data.apparent_temperature !== undefined ? data.apparent_temperature + '°C' : '--') + '</div>' +
              '<div>☂️ 降水: ' + (data.precipitation !== undefined ? data.precipitation + 'mm' : '--') + '</div>' +
              '<div>☀️ 紫外线: ' + (data.uv_index !== undefined ? data.uv_index : '--') + '</div>' +
              '<div>🌅 日出: ' + sunrise + '</div>' +
              '<div>🌇 日落: ' + sunset + '</div>' +
              '<div class="col-span-2 mt-0.5">📉 最高/低: ' + (data.temp_max !== undefined ? data.temp_max + '°C' : '--') + ' / ' + (data.temp_min !== undefined ? data.temp_min + '°C' : '--') + '</div>' +
              '<div class="col-span-2 mt-1.5 pt-1.5 border-t border-dashed border-black/5 dark:border-white/5 text-[0.6rem] text-black/40 dark:text-white/40 text-center leading-relaxed">🔒 隐私说明：天气服务基于本地缓存与 IP 近似位置提供，绝不收集或传输任何精确的个人定位隐私数据。</div>' +
            '</div>' +
          '</div>' +
        '</div>';

      // Bind toggle event
      var expandBtn = container.querySelector('.weather-expand-btn');
      var loadedContainer = container.querySelector('.weather-loaded');
      if (expandBtn && loadedContainer) {
        expandBtn.addEventListener('click', function() {
          loadedContainer.classList.toggle('weather-widget-expanded');
        });
      }
    }

    // ---- Main fetch with multi-tier location ----
    function fetchWeather() {
      var container = document.getElementById('weather-content');
      if (!container) return;

      // Step 1: Check localStorage cache
      var cached = getCachedLocation();
      if (cached) {
        doFetch(container, cached.lat, cached.lon, cached.name);
        return;
      }

      // Step 2: Try GPS (silent, only if already authorized)
      getGPS().then(function(gps) {
        if (gps) {
          cacheLocation(gps.lat, gps.lon, gps.name);
          doFetch(container, gps.lat, gps.lon, gps.name);
        } else {
          // Step 3: Let Worker decide (CF geo / ip-api / default)
          doFetch(container, null, null, null);
        }
      });
    }

    function doFetch(container, lat, lon, cityName) {
      var url = weatherApiUrl;
      if (lat && lon) {
        url += '?lat=' + lat + '&lon=' + lon;
        if (cityName) url += '&city=' + encodeURIComponent(cityName);
      }

      fetch(url)
        .then(function(res) {
          if (!res.ok) throw new Error('HTTP ' + res.status);
          return res.json();
        })
        .then(function(data) {
          renderWeather(container, data);
          // Cache the location from Worker response for next time
          if (data.city && !getCachedLocation()) {
            cacheLocation(data.latitude || lat, data.longitude || lon, data.city);
          }
        })
        .catch(function() {
          container.innerHTML = '<div class="weather-error">❌ 天气加载失败</div>';
        });
    }

    // Run
    fetchWeather();

    // Re-fetch on SPA navigation
    document.addEventListener('swup:contentReplaced', function() {
      setTimeout(fetchWeather, 100);
    });
  })();
</script>
